{
  "name": "mindgenius-ai",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "setup": "node scripts/setup.mjs",
    "dev": "pnpm --parallel -r dev",
    "dev:web": "pnpm --filter @mindgenius/web dev",
    "dev:server": "pnpm --filter @mindgenius/server dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "vitest run",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^0.41.0",
    "eslint": "^8.48.0",
    "lint-staged": "^14.0.1",
    "simple-git-hooks": "^2.9.0",
    "typescript": "^5.2.2",
    "vitest": "^1.6.0"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,cjs,mjs}": "eslint --fix"
  }
}
