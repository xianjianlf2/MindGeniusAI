# ===== 通用 =====
# 服务端口
PORT=3000
# 默认模型供应商: openai | anthropic | deepseek | moonshot（也可由请求头 X-LLM-Provider 覆盖）
LLM_PROVIDER=openai
# 日志级别: debug | info | warn | error
LOG_LEVEL=info

# ===== OpenAI =====
OPENAI_API_KEY=sk-xxx
# 自定义网关/代理（可选，需 OpenAI 协议兼容）
# OPENAI_PROXY_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# ===== Anthropic（可选）=====
# ANTHROPIC_API_KEY=sk-ant-xxx
# ANTHROPIC_MODEL=claude-sonnet-4-6

# ===== DeepSeek（可选）=====
# DEEPSEEK_API_KEY=sk-xxx
# DEEPSEEK_MODEL=deepseek-chat

# ===== Kimi / Moonshot（可选，OpenAI 协议兼容）=====
# MOONSHOT_API_KEY=sk-xxx
# 海外用 https://api.moonshot.ai/v1
# MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
# MOONSHOT_MODEL=moonshot-v1-8k          # 或 kimi-k2-… 等支持 function calling 的型号

# ===== RAG / 向量化 =====
# 注意：DeepSeek 与 Kimi 都不提供 embeddings 接口。chat 走它们时，
# 若要保留 PDF 检索，需单独指向一个 OpenAI 兼容的 embeddings 端点；
# 不配置则 rag_query 自动降级（仅画导图，不影响其他功能）。
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_API_KEY=sk-xxx               # 缺省回落到 OPENAI_API_KEY
# EMBEDDING_BASE_URL=https://api.openai.com/v1   # 缺省回落到 OPENAI_PROXY_URL

# ===== 上传/索引护栏（保护免费托管不被拖垮）=====
# DISABLE_UPLOAD=true                    # 彻底关闭 PDF 上传（纯画导图）
# MAX_UPLOAD_MB=10                       # 单文件大小上限（默认 10MB，超出 413）
# MAX_INDEXED_DOCS=20                    # 进程内最多索引文档数，超出淘汰最旧
# MAX_CHUNKS_PER_DOC=200                 # 单文档最多分块数，挡超大文档
