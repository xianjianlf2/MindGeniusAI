# 前端可选配置（构建时注入，需 VITE_ 前缀）。复制为 .env 后填写。
# 不配置则统计整体为静默 no-op，本地开发无需理会。

# 隐私友好、无 cookie 的统计供应商：umami | goatcounter | cloudflare
# VITE_ANALYTICS_PROVIDER=umami

# --- umami（推荐：一个脚本同时统计 PV/UV + 自定义事件 agent_run）---
# VITE_UMAMI_WEBSITE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# VITE_UMAMI_SRC=https://cloud.umami.is/script.js

# --- goatcounter（开源项目免费，同样支持事件）---
# VITE_GOATCOUNTER_ENDPOINT=https://你的码.goatcounter.com/count

# --- cloudflare Web Analytics（仅 PV/UV，不支持自定义事件 agent_run）---
# VITE_CF_BEACON_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
